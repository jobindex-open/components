{
    "name": "jobindex-components-workspace",
    "private": true,
    "packageManager": "yarn@1.22.22",
    "scripts": {
        "dev": "turbo run dev",
        "test": "turbo run test",
        "build": "turbo run build build:types",
        "lint": "turbo run lint",
        "clean": "turbo run clean",
        "format": "prettier -w .",
        "release": "changeset publish",
        "prepare": "husky"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "dependencies": {
        "vue": "^3.5.32"
    },
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "@tsconfig/node20": "^20.1.9",
        "@types/node": "^25.6.0",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vitest/browser": "^4.1.4",
        "@vitest/browser-playwright": "^4.1.4",
        "@vitest/coverage-v8": "^4.1.4",
        "@vue/language-server": "^3.2.6",
        "@vue/tsconfig": "^0.9.1",
        "@vue/typescript-plugin": "^3.0.6",
        "globals": "^17.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "playwright": "^1.59.1",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "turbo": "^2.9.6",
        "typescript": "^6.0.3",
        "vite": "^8.0.8",
        "vitest": "^4.1.4",
        "vitest-browser-vue": "^2.1.0",
        "vue-tsc": "^3.2.6"
    },
    "lint-staged": {
        "*.(jsx?|tsx?|vue|md|s?css)": "prettier --write",
        "*.(jsx?|tsx?|vue)": "eslint --fix"
    }
}
