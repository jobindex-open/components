{
    "name": "@jobindex/common",
    "type": "module",
    "version": "0.1.0",
    "private": true,
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        "./*": "./src/*",
        "./package.json": "./package.json"
    },
    "scripts": {
        "lint": "eslint --max-warnings 0",
        "test:watch": "vitest",
        "test": "vitest run",
        "coverage": "vitest run --coverage",
        "clean": "rimraf ./dist ./coverage"
    },
    "devDependencies": {
        "@jobindex/config-ts": "workspace:*",
        "@jobindex/config-eslint": "workspace:*",
        "@types/node": "^25.8.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.13",
        "vitest": "^4.1.6"
    }
}
